# ============================================
# AI 健康管理系统 - 环境变量模板
# 复制为 .env 并修改实际值
# ============================================

# 数据库
DB_URL=jdbc:mysql://localhost:3306/ai_health_db?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT密钥 (生产环境请用 openssl rand -base64 64 生成)
JWT_SECRET=your-jwt-secret-key-at-least-256-bits

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# CORS 允许的来源 (多个用逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://localhost

# 短信服务 (生产环境设为 false 接入真实短信)
SMS_DEV_MODE=true

# AES-256-GCM 字段级加密密钥（Base64 编码）
# 生成: openssl rand -base64 32
AES_ENCRYPTION_KEY=your-aes-256-key-base64-32bytes
# 旧密钥（密钥轮换过渡期兼容，可选）
AES_ENCRYPTION_LEGACY_KEY=

# ============================================
# Phase 4：高并发与成本精细化
# ============================================

# ShardingSphere 读写分离（生产环境启用）
SHARDING_ENABLED=false
DB_MASTER_URL=jdbc:mysql://master-host:3306/ai_health_system?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=true
DB_MASTER_USERNAME=root
DB_MASTER_PASSWORD=your-master-password
DB_SLAVE0_URL=jdbc:mysql://slave0-host:3307/ai_health_system?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=true
DB_SLAVE0_USERNAME=root
DB_SLAVE0_PASSWORD=your-slave0-password
DB_SLAVE1_URL=jdbc:mysql://slave1-host:3307/ai_health_system?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=true
DB_SLAVE1_USERNAME=root
DB_SLAVE1_PASSWORD=your-slave1-password

# 本地 Ollama 模型（替代 30% 云端调用）
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b
OLLAMA_BACKUP_MODEL=llama3:8b

# 成本预算（单用户日限额，元）
COST_DAILY_PER_USER=1.0
COST_AUTO_PAUSE=1.0
COST_ALERT_WEBHOOK=

# 备选云端模型 API Key
QWEN_API_KEY=sk-your-qwen-api-key
GLM_API_KEY=your-glm-api-key
MOONSHOT_API_KEY=sk-your-moonshot-api-key