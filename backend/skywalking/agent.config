# ============================================================================
# SkyWalking Agent 配置文件（Phase 3 全链路追踪）
# ============================================================================
# 使用方式：java -javaagent:skywalking-agent.jar -Dskywalking_config=agent.config -jar app.jar
# 从 Phase 1 开启，用于收集性能基线对比数据

# 服务名称（在 SkyWalking UI 中显示）
agent.service_name=ai-health-system

# SkyWalking OAP 后端地址（gRPC）
collector.backend_service=127.0.0.1:11800

# 日志级别
logging.level=INFO

# 忽略追踪的端点（健康检查等）
# 多个用逗号分隔
trace.ignore_path=${SW_IGNORE_PATH:/health,/actuator/**,/swagger-ui/**}

# 采样率（-1=全部, 0=none, 1~10000=每N秒最多N条）
agent.sample_n_per_3_secs=-1

# 上报数据最大 Span 数
agent.span_limit_per_segment=300

# Trace ID 传播（从 HTTP Header 提取，匹配前端 x-request-id）
plugin.toolkit.log.transmit_formatted=true

# ============================================================================
# Spring 相关插件
# ============================================================================
plugin.springmvc.collect_http_params=true
plugin.springmvc.http_params_length_threshold=1024

# ============================================================================
# 数据库追踪
# ============================================================================
plugin.jdbc.trace_sql_parameters=true
plugin.jdbc.sql_parameters_max_length=512

# ============================================================================
# 性能阈值（超过时自动标记为慢查询）
# ============================================================================
plugin.mongodb.trace_param=true