## 四、低优先级：RAGAS质量监控
### 核心问题
缺少对RAG系统质量的量化监控，无法及时发现检索召回率下降或幻觉率上升的问题。
### 完整实现代码
```java
// com/example/evaluation/RagasMonitor.java
@Slf4j
@Component
public class RagasMonitor {
    @Autowired
    private MemoryService memoryService;
    @Autowired
    private KnowledgeService knowledgeService;
    @Autowired
    private PrometheusMetricsExporter metrics;
    @Autowired
    private AlertManager alertManager;

    // 每日凌晨2点运行RAG质量检查
    @Scheduled(cron = "0 0 2 * * ?")
    public void runRagasEvaluation() {
        log.info("开始运行RAGAS质量监控");
        
        // 1. 计算上下文召回率：检索结果中包含正确答案的比例
        double contextRecall = calculateContextRecall();
        // 2. 计算答案忠实度：AI答案与检索上下文的一致性
        double answerFaithfulness = calculateAnswerFaithfulness();
        // 3. 计算幻觉率：AI答案中不在检索上下文中的内容比例
        double hallucinationRate = calculateHallucinationRate();

        // 记录指标到Prometheus
        Gauge.builder("rag_context_recall")
                .description("RAG上下文召回率")
                .register(metrics.getMeterRegistry())
                .set(contextRecall);
        
        Gauge.builder("rag_hallucination_rate")
                .description("RAG幻觉率")
                .register(metrics.getMeterRegistry())
                .set(hallucinationRate);

        // 告警：指标低于阈值时触发
        if (contextRecall < 0.9) {
            alertManager.sendWarningAlert("RAG召回率下降预警", 
                String.format("当前召回率: %.2f, 低于阈值0.9", contextRecall));
        }
        if (hallucinationRate > 0.05) {
            alertManager.sendWarningAlert("RAG幻觉率上升预警", 
                String.format("当前幻觉率: %.2f, 高于阈值0.05", hallucinationRate));
        }

        log.info("RAGAS质量检查完成：召回率={}, 忠实度={}, 幻觉率={}", 
            contextRecall, answerFaithfulness, hallucinationRate);
    }

    // 简化版召回率计算：使用黄金测试集
    private double calculateContextRecall() {
        List<RagasTestCase> testCases = ragasTestCaseMapper.selectAll();
        int correct = 0;
        for (RagasTestCase testCase : testCases) {
            List<String> retrieved = knowledgeService.retrieve(testCase.getQuery(), 3)
                    .stream()
                    .map(KnowledgeDoc::getContent)
                    .toList();
            if (retrieved.contains(testCase.getExpectedContext())) {
                correct++;
            }
        }
        return (double) correct / testCases.size();
    }

    // 其他指标计算逻辑类似，使用LLM-as-Judge评分
}
```

