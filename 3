@Autowired
private PrometheusMetricsExporter metrics;

public String callApi(String prompt, String model) {
    long start = System.currentTimeMillis();
    try {
        // 原有调用逻辑
        String response = doCall(prompt, model);
        metrics.recordAiCall("chat", model, true, System.currentTimeMillis() - start);
        metrics.recordTokenConsumption(model, inputTokens, outputTokens);
