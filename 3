## 一、最高优先级：OnlineSafetyCircuitBreaker 独立安全熔断器
### 核心问题
当前熔断逻辑分散在`LLMEvaluator`中，无明确状态机，无法实现工业级的熔断-恢复流程。
### 完整实现代码
#### 1. 状态枚举与配置
```java
// com/example/resilience/CircuitState.java
public enum CircuitState {
    CLOSED,      // 正常运行
    OPEN,        // 熔断中，所有请求走降级
    HALF_OPEN    // 探测恢复中，允许少量请求通过
}

// com/example/resilience/SafetyCircuitConfig.java
@Data
@Component
@ConfigurationProperties(prefix = "safety.circuit")
public class SafetyCircuitConfig {
    // 熔断阈值
    private double safetyThreshold = 9.0;        // 安全分低于9.0触发预警
    private double meltdownThreshold = 7.5;      // 低于7.5立即熔断
    private int consecutiveFailsToOpen = 5;      // 连续5次低分触发熔断
    private int slidingWindowMinutes = 30;       // 30分钟滑动窗口
    private int halfOpenTestInterval = 10;       // 熔断后每10分钟探测一次
    private int halfOpenTestCount = 3;           // 每次探测3个请求
}
```

#### 2. 独立熔断器核心类
```java
// com/example/resilience/OnlineSafetyCircuitBreaker.java
@Slf4j
@Component
public class OnlineSafetyCircuitBreaker {
    private final SafetyCircuitConfig config;
    private final LLMEvaluator llmEvaluator;
    private final AlertManager alertManager;
    private final ModelRouter modelRouter;

    // 状态机
    private volatile CircuitState currentState = CircuitState.CLOSED;
    // 滑动窗口：存储最近30分钟的安全评分
    private final EvictingQueue<Double> safetyScoreWindow = EvictingQueue.create(100);
    // 连续失败计数器
    private final AtomicInteger consecutiveFails = new AtomicInteger(0);
    // 熔断开始时间
    private volatile long openTime = 0;

    public OnlineSafetyCircuitBreaker(SafetyCircuitConfig config, LLMEvaluator llmEvaluator,
                                      AlertManager alertManager, ModelRouter modelRouter) {
        this.config = config;
        this.llmEvaluator = llmEvaluator;
        this.alertManager = alertManager;
        this.modelRouter = modelRouter;
    }

    /**
     * 每次AI调用后记录安全评分，判断是否触发熔断
     */
    public synchronized void recordSafetyScore(double score) {
        safetyScoreWindow.add(score);
        
        if (score < config.getSafetyThreshold()) {
            int fails = consecutiveFails.incrementAndGet();
            log.warn("安全评分低于阈值: {}, 连续失败次数: {}", score, fails);
            
            // 触发熔断条件
            if (fails >= config.getConsecutiveFailsToOpen() || score < config.getMeltdownThreshold()) {
                tripCircuit(score);
            }
        } else {
            consecutiveFails.set(0);
            // 如果是半开状态，所有探测请求都通过则恢复
            if (currentState == CircuitState.HALF_OPEN) {
                if (safetyScoreWindow.stream().filter(s -> s >= config.getSafetyThreshold()).count() 
                        >= config.getHalfOpenTestCount()) {
                    closeCircuit();
                }
            }
        }
    }

    /**
     * 检查是否允许AI调用（熔断时返回false，走降级方案）
     */
    public boolean allowAiCall() {
        if (currentState == CircuitState.CLOSED) {
            return true;
        }
        
        if (currentState == CircuitState.OPEN) {
            // 检查是否到了探测时间
            if (System.currentTimeMillis() - openTime > config.getHalfOpenTestInterval() * 60 * 1000L) {
                currentState = CircuitState.HALF_OPEN;
                log.info("进入半开状态，开始探测恢复");
                return true; // 允许第一个探测请求
            }
            return false;
        }
        
        // 半开状态：只允许配置数量的探测请求
        return safetyScoreWindow.stream()
                .filter(s -> s >= config.getSafetyThreshold())
                .count() < config.getHalfOpenTestCount();
    }

    /**
     * 触发熔断
     */
    private void tripCircuit(double currentScore) {
        if (currentState == CircuitState.OPEN) return;
        
        currentState = CircuitState.OPEN;
        openTime = System.currentTimeMillis();
        consecutiveFails.set(0);
        safetyScoreWindow.clear();
        
        log.error("安全熔断器触发！当前安全分: {}, 已自动切换至规则引擎降级", currentScore);
        alertManager.sendP0Alert("AI安全熔断触发", 
            String.format("近30分钟平均安全分: %.2f, 连续失败次数: %d, 已切换至规则引擎", 
                getAverageSafetyScore(), consecutiveFails.get()));
    }

    /**
     * 恢复正常
     */
    private void closeCircuit() {
        currentState = CircuitState.CLOSED;
        openTime = 0;
        consecutiveFails.set(0);
        safetyScoreWindow.clear();
        
        log.info("安全熔断器恢复正常");
        alertManager.sendInfoAlert("AI安全熔断已恢复", "当前安全分已达标，恢复正常AI调用");
    }

    /**
     * 获取滑动窗口平均安全分
     */
    public double getAverageSafetyScore() {
        return safetyScoreWindow.stream()
                .mapToDouble(Double::doubleValue)
                .average()
                .orElse(10.0);
    }

    public CircuitState getCurrentState() {
        return currentState;
    }
}
```

