#### 3. 标准指标定义与导出
```java
// com/example/llmops/PrometheusMetricsExporter.java
@Component
public class PrometheusMetricsExporter {
    private final MeterRegistry meterRegistry;

    // 1. Counter：计数类指标
    public final Counter aiCallCounter;
    public final Counter tokenConsumptionCounter;
    public final Counter safetyBlockCounter;
    public final Counter circuitBreakerTripCounter;

    // 2. Histogram：分布类指标
    public final Histogram aiCallLatencyHistogram;
    public final Histogram ragRetrievalLatencyHistogram;

    // 3. Gauge：瞬时值指标
    public final Gauge circuitBreakerStateGauge;
    public final Gauge averageSafetyScoreGauge;

    public PrometheusMetricsExporter(MeterRegistry meterRegistry, OnlineSafetyCircuitBreaker circuitBreaker) {
        this.meterRegistry = meterRegistry;

        // 初始化Counter
        this.aiCallCounter = Counter.builder("ai_call_total")
                .description("AI调用总次数")
                .tags("call_type", "model", "status")
                .register(meterRegistry);

        this.tokenConsumptionCounter = Counter.builder("ai_token_consumption_total")
                .description("Token消耗总量")
                .tags("model", "type")
                .register(meterRegistry);

        // 初始化Histogram
        this.aiCallLatencyHistogram = Histogram.builder("ai_call_latency_seconds")
                .description("AI调用延迟分布")
                .tags("call_type")
                .register(meterRegistry);

        // 初始化Gauge
        this.circuitBreakerStateGauge = Gauge.builder("ai_circuit_breaker_state")
                .description("安全熔断器状态：0=CLOSED,1=OPEN,2=HALF_OPEN")
                .register(meterRegistry, circuitBreaker, cb -> switch (cb.getCurrentState()) {
                    case CLOSED -> 0;
                    case OPEN -> 1;
                    case HALF_OPEN -> 2;
                });

        this.averageSafetyScoreGauge = Gauge.builder("ai_average_safety_score")
                .description("30分钟滑动窗口平均安全分")
                .register(meterRegistry, circuitBreaker, OnlineSafetyCircuitBreaker::getAverageSafetyScore);
    }

    // 工具方法：记录AI调用
    public void recordAiCall(String callType, String model, boolean success, long latencyMs) {
        aiCallCounter.labels(callType, model, success ? "success" : "fail").increment();
        aiCallLatencyHistogram.labels(callType).record(latencyMs / 1000.0);
    }

    // 工具方法：记录Token消耗
    public void recordTokenConsumption(String model, int inputTokens, int outputTokens) {
        tokenConsumptionCounter.labels(model, "input").increment(inputTokens);
        tokenConsumptionCounter.labels(model, "output").increment(outputTokens);
    }
}
```

