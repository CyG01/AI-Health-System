// com/example/agent/orchestrator/AgentOrchestrator.java
@Autowired
private OnlineSafetyCircuitBreaker circuitBreaker;

public AiAgentResponse orchestrate(Long userId, String userInput) {
    // 第一步：检查熔断器状态
    if (!circuitBreaker.allowAiCall()) {
        log.warn("安全熔断器已触发，返回规则引擎降级计划");
        return fallbackService.getFallbackResponse(userId, userInput);
    }
    
    // 原有逻辑：路由Agent → 执行 → 安全审查
    AiAgentResponse response = executeAgents(userId, userInput);
    
    // 第二步：记录安全评分
    double safetyScore = safetyReviewAgent.review(response);
    circuitBreaker.recordSafetyScore(safetyScore);
    
    return response;
}
